<!DOCTYPE html>
<html>
<head>
<title>Candy Treasure</title>
<style>
body{
  text-align:center;
  font-family:Arial;
  margin-top:50px;
}
button{
  padding:15px 25px;
  font-size:20px;
}
</style>
</head>
<body>

<h1>🍬 Candy Treasure 🍬</h1>
<h2>Score: <span id="score">0</span></h2>

<button onclick="collectCandy()">Collect Candy</button>

<script>
let score = 0;

function collectCandy(){
  score++;
  document.getElementById("score").innerText = score;
}
</script>

</body>
</html>
